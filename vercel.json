{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "nz-election-tracker.com" }],
      "destination": "https://nz-election-tracker.co.nz/:path",
      "permanent": true
    },
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "www.nz-election-tracker.com" }],
      "destination": "https://nz-election-tracker.co.nz/:path",
      "permanent": true
    }
  ]
}
